//场景介绍：
// 1. 在Host端构造原始数据，并将数据通过参数传递到Device端。
// 2. 在设备端, 对32位浮点数据按元素插入。用标量ra替代向量va中由n指定的元素，组成并返回新的向量。
// 3. 在Host端对结果进行打印。



#define INS_VAL 100
#define NUM 32

__global__ void test(short *sval) {
    // 使用0号计算核心进行运算
    if (threadIdx == 0) {
        shortv32 vsval, vsval2;
        const int idx = 12;
        simd_load(vsval, sval);
        vsval2 = simd_ins((short)(INS_VAL), vsval, idx);
        simd_store(vsval2, sval);
    }
}

int main() {
    int i = 0;
    // 分配Host端地址
    short *sval = (short *)malloc(NUM * sizeof(short));
    short *sval_refer = (short *)malloc(NUM * sizeof(short));
    //  设置插入的指定元素
    const int idx = 12;

    // 为分配的Host地址进行初始化
    for (i = 0; i < NUM; i++) {
        sval[i] = 123 + i;
        sval_refer[i] = 123.21 + i;
        if (i == idx) {
            sval_refer[i] = INS_VAL;
        }
    }
    //  声明Device端地址
    short *sval_slave = NULL;
    //  配置使用0号计算核心阵列
    sdaaSetDevice(0);
    //  使用sdaaMalloc为Device端地址进行空间分配
    sdaaMalloc((void **)(&sval_slave), NUM * sizeof(short));
    //  使用sdaaMemcpy将Host端内存拷贝到Device端
    sdaaMemcpy(sval_slave, sval, NUM * sizeof(short), sdaaMemcpyHostToDevice);
    //  启动核函数调用
    test<<<1>>>(sval_slave);
    //  等待计算核心SPE完成之前的所有请求任务
    sdaaDeviceSynchronize();
    //  使用sdaaMemcpy将Device端数据拷贝到Host端
    sdaaMemcpy(sval, sval_slave, NUM * sizeof(short), sdaaMemcpyDeviceToHost);
    //  打印设备端处理完成的数据
    for (i = 0; i < NUM; i++) {
        printf("sval = %d, sval_refer= %d\n", sval[i], sval_refer[i]);
    }
    //  释放Device端内存
    sdaaFree(sval);
    //  释放host端内存
    free(sval);
    free(sval_refer);

    return 0;
}
